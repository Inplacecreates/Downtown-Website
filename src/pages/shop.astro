---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

/*
 * /shop page. Marketing-style storefront: every product is a
 * "tap to order on WhatsApp" intent capture rather than an
 * in-page checkout. Real payments and inventory live behind a
 * future M-Pesa + Stripe build; this page exists so we can start
 * selling on day one without that infra.
 *
 * Every product carries a pillar tag, and the pillar pages
 * cross-link back to the merch that funds them. The funding
 * narrative is the page: choose the pillar you want to support,
 * choose the item that funds it.
 */

/*
 * REPLACE BEFORE LAUNCH. Downtown's WhatsApp business number in
 * international format, no leading + or 0. Example: a Kenyan
 * mobile +254 712 345 678 becomes "254712345678". Used to build
 * the wa.me deeplinks for every product order button.
 */
const WHATSAPP_NUMBER = "254700000000";

const products = await getCollection("products");

/*
 * Category order on the page. Mirrors the schema enum so all
 * registered categories appear in a predictable visual sequence.
 */
const categoryOrder = [
  "Hoodie",
  "T-shirt",
  "Wristband",
  "Mug",
  "Water bottle",
  "Keyholder",
  "Tote",
  "Print",
] as const;

const sortedProducts = [...products].sort((a, b) => {
  const ca = categoryOrder.indexOf(a.data.category);
  const cb = categoryOrder.indexOf(b.data.category);
  return ca - cb;
});

/*
 * Funding-stats strip data. totalProducts is the cardinality of
 * the line; lanesFunded counts the distinct pillars receiving at
 * least one product's revenue. 100% to programmes is editorial,
 * not computed, but lives near the others for editorial clarity.
 */
const totalProducts = sortedProducts.length;
const lanesFunded = new Set(sortedProducts.map((p) => p.data.pillar)).size;

/*
 * Pillar slug → display label. Sourced from the pillars collection
 * so adding a pillar doesn't desync the shop labels.
 */
const pillars = await getCollection("pillars");
const pillarNames = Object.fromEntries(
  pillars.map((p) => [p.id, p.data.name]),
) as Record<string, string>;

/*
 * Build the WhatsApp order link. Pre-fills a polite intent message
 * so the customer arrives at the conversation with their order
 * stated; Downtown staff close on availability and payment.
 */
const buildOrderHref = (
  product: (typeof products)[number]["data"],
) => {
  const msg = `Hi Downtown, I'd like to order the ${product.name} (${product.price}). Could you confirm availability and arrange pickup or delivery?`;
  return `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;
};
---

<Layout
  title="Shop · Downtown"
  description="Hoodies, tees, wristbands, mugs, bottles, prints. Every order funds one of the seven pillars of Downtown's creative programme."
>
  <article>
    {/* Hero */}
    <section class="border-b border-border">
      <div
        class="mx-auto max-w-[1440px] px-6 pt-24 md:px-12 md:pt-32 lg:px-20 lg:pt-40"
      >
        <p
          class="reveal font-mono text-sm uppercase tracking-wider text-muted-foreground"
        >
          The shop
        </p>
        <h1
          class="reveal mt-6 font-display font-black uppercase tracking-tight text-[clamp(48px,9vw,128px)] leading-[0.95]"
          style="transition-delay: 100ms"
        >
          Wear the <span class="bg-bonfire px-3 text-ink">place</span>.
        </h1>
        <p
          class="reveal mt-8 max-w-prose font-sans text-xl leading-relaxed"
          style="transition-delay: 200ms"
        >
          Every order funds one of the seven pillars. The wristband
          funds Youth. The bottle funds Stage. The hoodie funds
          Music. Choose the pillar you want to support; choose the
          item that funds it.
        </p>
        <p
          class="reveal mt-6 max-w-prose font-sans text-base leading-relaxed text-muted-foreground"
          style="transition-delay: 300ms"
        >
          Ordering is by WhatsApp for now: tap an item, the message
          opens pre-filled, our team replies with availability and
          arranges pickup or delivery. Card and M-Pesa checkout
          arrives later this year.
        </p>

        {/*
         * Funding-stats strip. Reinforces the case-the-page-makes
         * with three numbers a reader can scan in under a second.
         * Computed from the collection so the figures stay honest
         * as the line expands.
         */}
        <dl
          class="reveal mt-14 grid grid-cols-1 gap-6 border-y border-border py-6 sm:grid-cols-3 sm:gap-10 md:mt-20"
          style="transition-delay: 400ms"
        >
          <div class="flex items-baseline gap-4">
            <dt class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
              Products
            </dt>
            <dd class="font-display text-3xl font-black tracking-tight md:text-4xl">
              {totalProducts}
            </dd>
          </div>
          <div class="flex items-baseline gap-4">
            <dt class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
              Lanes funded
            </dt>
            <dd class="font-display text-3xl font-black tracking-tight md:text-4xl">
              {lanesFunded}
            </dd>
          </div>
          <div class="flex items-baseline gap-4">
            <dt class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
              To programmes
            </dt>
            <dd class="font-display text-3xl font-black tracking-tight md:text-4xl">
              100<span class="text-xl text-bonfire">%</span>
            </dd>
          </div>
        </dl>
      </div>
    </section>

    {/* Product grid */}
    <section class="border-b border-border">
      <div
        class="mx-auto max-w-[1440px] px-6 py-20 md:px-12 md:py-28 lg:px-20"
      >
        <ul class="grid gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-3 lg:gap-10">
          {
            sortedProducts.map((entry, i) => {
              const p = entry.data;
              const pillarLabel = pillarNames[p.pillar] ?? p.pillar;
              const orderHref = buildOrderHref(p);
              return (
                <li
                  class="reveal"
                  style={`transition-delay: ${200 + i * 60}ms`}
                >
                  <article class="group flex h-full flex-col border border-border bg-cream transition-all duration-300 hover:-translate-y-1 hover:border-bonfire hover:shadow-[0_18px_36px_-18px_rgba(20,20,20,0.18)]">
                    {/*
                     * Icon zone. Replaces the previous product image:
                     * a faint category watermark behind a shopping
                     * bag glyph. Same icon for every product so the
                     * differentiation is text, not photography that
                     * doesn't exist yet. Hover lifts and recolours
                     * the icon to bonfire so the card responds.
                     */}
                    <div class="relative flex aspect-square items-center justify-center overflow-hidden border-b border-border bg-smoke">
                      <span
                        aria-hidden="true"
                        class="pointer-events-none absolute inset-0 flex items-center justify-center whitespace-nowrap font-display text-[7rem] font-black uppercase leading-none tracking-tighter text-concrete/[0.06] md:text-[8rem]"
                      >
                        {p.category}
                      </span>
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.25"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                        class="relative h-20 w-20 text-concrete transition-all duration-300 group-hover:scale-110 group-hover:text-bonfire md:h-24 md:w-24"
                      >
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                        <path d="M3 6h18" />
                        <path d="M16 10a4 4 0 0 1-8 0" />
                      </svg>
                      <p class="absolute left-5 top-5 font-mono text-xs uppercase tracking-wider text-concrete">
                        {p.category}
                      </p>
                      {!p.inStock && (
                        <p class="absolute right-5 top-5 border border-concrete/30 bg-cream px-2 py-1 font-mono text-[10px] uppercase tracking-wider text-concrete">
                          Sold out
                        </p>
                      )}
                    </div>

                    {/* Content */}
                    <div class="flex flex-1 flex-col p-6 md:p-7">
                      <h3 class="font-display text-2xl font-black uppercase leading-tight tracking-tight md:text-3xl">
                        {p.name}
                      </h3>

                      <p class="mt-3 font-sans text-base leading-relaxed text-foreground">
                        {p.tagline}
                      </p>

                      <p class="mt-4 font-mono text-lg text-bonfire">
                        {p.price}
                      </p>

                      {p.variants.length > 0 && (
                        <ul class="mt-4 space-y-1 font-mono text-xs uppercase tracking-wider text-muted-foreground">
                          {p.variants.map((v) => (
                            <li>
                              {v.label}: {v.options.join(" · ")}
                            </li>
                          ))}
                        </ul>
                      )}

                      {/* Spacer pushes the CTAs to the bottom so
                          cards of different content length line up
                          their order buttons. */}
                      <div class="mt-auto pt-6">
                        <a
                          href={`/pillars/${p.pillar}`}
                          class="inline-flex items-center gap-2 border border-bonfire/40 px-3 py-1.5 font-mono text-xs uppercase tracking-wider text-bonfire transition-colors hover:bg-bonfire hover:text-ink focus-visible:bg-bonfire focus-visible:text-ink focus-visible:outline-none"
                        >
                          <span aria-hidden="true" class="h-2 w-2 bg-bonfire" />
                          Funds {pillarLabel}
                        </a>

                        <a
                          href={p.inStock ? orderHref : undefined}
                          target="_blank"
                          rel="noopener"
                          aria-disabled={!p.inStock}
                          class:list={[
                            "mt-4 inline-flex w-full items-center justify-center gap-3 px-6 py-4 font-mono text-sm uppercase tracking-wider transition-all duration-200",
                            p.inStock
                              ? "bg-bonfire text-ink hover:opacity-90"
                              : "pointer-events-none border border-border text-muted-foreground",
                          ]}
                        >
                          <span>{p.inStock ? "Order on WhatsApp" : "Notify me"}</span>
                          {p.inStock && (
                            <span
                              aria-hidden="true"
                              class="inline-block transition-transform duration-200 group-hover:translate-x-0.5"
                            >
                              →
                            </span>
                          )}
                        </a>
                      </div>
                    </div>
                  </article>
                </li>
              );
            })
          }
        </ul>
      </div>
    </section>

    {/* How it works (polarity flip) */}
    <section class="dark border-b border-border bg-background text-foreground">
      <div
        class="mx-auto max-w-[1440px] px-6 py-20 md:px-12 md:py-28 lg:px-20"
      >
        <p
          class="reveal font-mono text-sm uppercase tracking-wider text-muted-foreground"
        >
          How to order
        </p>
        <h2
          class="reveal mt-6 font-display font-black uppercase tracking-tight text-[clamp(36px,6vw,72px)] leading-[1.0]"
          style="transition-delay: 100ms"
        >
          Three steps.
        </h2>

        <ol class="mt-16 grid gap-px bg-border md:grid-cols-3">
          <li
            class="reveal bg-background p-8 md:p-10"
            style="transition-delay: 200ms"
          >
            <span class="font-mono text-xs uppercase tracking-wider text-bonfire">
              01
            </span>
            <h3 class="mt-4 font-display text-2xl font-black uppercase tracking-tight md:text-3xl">
              Tap the item.
            </h3>
            <p class="mt-4 font-sans text-base leading-relaxed">
              WhatsApp opens with your order pre-filled. Edit it if
              you want a different size, colour, or quantity before
              sending.
            </p>
          </li>
          <li
            class="reveal bg-background p-8 md:p-10"
            style="transition-delay: 280ms"
          >
            <span class="font-mono text-xs uppercase tracking-wider text-bonfire">
              02
            </span>
            <h3 class="mt-4 font-display text-2xl font-black uppercase tracking-tight md:text-3xl">
              We confirm.
            </h3>
            <p class="mt-4 font-sans text-base leading-relaxed">
              Our team replies same-day with availability, the
              total, and payment options (M-Pesa, bank, card on
              pickup).
            </p>
          </li>
          <li
            class="reveal bg-background p-8 md:p-10"
            style="transition-delay: 360ms"
          >
            <span class="font-mono text-xs uppercase tracking-wider text-bonfire">
              03
            </span>
            <h3 class="mt-4 font-display text-2xl font-black uppercase tracking-tight md:text-3xl">
              Pickup or delivery.
            </h3>
            <p class="mt-4 font-sans text-base leading-relaxed">
              Collect from Downtown any open evening, or ship in
              Kenya via courier. Bonus: pickup at the bar gets you
              a free drink while you fit your hoodie.
            </p>
          </li>
        </ol>

        <p
          class="reveal mt-16 max-w-prose font-sans text-base leading-relaxed text-muted-foreground"
          style="transition-delay: 500ms"
        >
          Full card and M-Pesa checkout, plus international
          shipping, arrive when our fulfilment partner is in place.
          For now the WhatsApp route keeps things honest: a real
          person at our end, every time.
        </p>
      </div>
    </section>
  </article>
</Layout>
