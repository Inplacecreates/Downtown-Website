---
import Layout from "../layouts/Layout.astro";

/*
 * Brand-voiced 404. Heading uses the locked microcopy from DESIGN.md
 * section 8 ("Not on the bill."), Bonfire orange flags the 404 status
 * code in the mono kicker so the technical fact is still legible
 * without breaking voice.
 */
---

<Layout
  title="Not on the bill · Downtown"
  description="The page you wanted isn't on this weekend's programme."
>
  <section>
    <div
      class="mx-auto max-w-[1440px] px-6 py-32 md:px-12 md:py-48 lg:px-20 lg:py-56"
    >
      <p
        class="reveal font-mono text-sm uppercase tracking-wider text-bonfire"
      >
        404
      </p>

      <h1
        class="reveal mt-6 font-display font-black uppercase tracking-tight text-[clamp(48px,9vw,128px)] leading-[0.95]"
        style="transition-delay: 100ms"
      >
        Not on the bill.
      </h1>

      <p
        class="reveal mt-8 max-w-prose font-sans text-lg"
        style="transition-delay: 200ms"
      >
        Whatever you came for, it isn't on this weekend's programme.
      </p>

      <a
        href="/"
        class="reveal mt-12 inline-flex items-center gap-3 bg-primary px-6 py-4 font-mono text-sm font-semibold uppercase tracking-wider text-primary-foreground transition-opacity hover:opacity-90"
        style="transition-delay: 300ms"
      >
        Back to Downtown
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
