---
import Wordmark from "./Wordmark.astro";

/*
 * Header with the SVG wordmark. The wordmark inherits text colour via
 * currentColor, so the bars match whichever polarity the section is in.
 *
 * Active-state highlighting: the current pathname is compared against
 * each nav entry's prefix so /pillars/* keeps Vision highlighted and
 * /shop highlights Shop. Shop is styled as a filled bonfire button
 * (rather than a plain link) so it pulls the eye, and on hover the
 * label morphs from "Shop" to "Support" with a shutter transition.
 * The "Support" framing turns merch into a community-funding action;
 * the morph happens in pure CSS via stacked spans + transform.
 */
const path = Astro.url.pathname;
const textLinks = [
  { href: "/#whats-on", label: "What's on", match: (p: string) => p === "/" },
  {
    href: "/community",
    label: "Community",
    match: (p: string) =>
      p.startsWith("/community") ||
      p.startsWith("/residents") ||
      p.startsWith("/djs"),
  },
  {
    href: "/vision",
    label: "Vision",
    match: (p: string) => p.startsWith("/vision") || p.startsWith("/pillars"),
  },
];
const shopActive = path.startsWith("/shop");
---

<header class="border-b border-border">
  <div
    class="mx-auto flex max-w-[1440px] items-center justify-between px-6 py-6 md:px-12 lg:px-20"
  >
    <a
      href="/"
      class="block w-[88px] text-foreground transition-opacity hover:opacity-90 md:w-[120px]"
    >
      <Wordmark />
    </a>

    <nav class="flex items-center gap-4 md:gap-7">
      {
        textLinks.map((item) => {
          const isActive = item.match(path);
          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "hidden font-sans text-sm font-semibold uppercase tracking-wide transition-colors hover:text-bonfire sm:inline-flex",
                isActive && "text-bonfire",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }

      <a
        href="/shop"
        aria-current={shopActive ? "page" : undefined}
        aria-label="Shop and support Downtown"
        class:list={[
          "group inline-flex items-center gap-2 border-2 px-4 py-2 font-sans text-sm font-semibold uppercase tracking-wide transition-colors duration-200",
          shopActive
            ? "border-bonfire bg-bonfire text-ink"
            : "border-bonfire bg-bonfire text-ink hover:bg-ink hover:text-bonfire",
        ]}
      >
        {/* Shutter morph: an invisible "Support" span gives the
            container its width so the label longest-word doesn't
            jump. Two absolute spans (Shop default, Support hover)
            slide vertically on hover. */}
        <span class="relative inline-block overflow-hidden">
          <span aria-hidden="true" class="invisible block">Support</span>
          <span class="absolute inset-0 text-center transition-transform duration-300 ease-out group-hover:-translate-y-full group-focus-visible:-translate-y-full">
            Shop
          </span>
          <span class="absolute inset-0 translate-y-full text-center transition-transform duration-300 ease-out group-hover:translate-y-0 group-focus-visible:translate-y-0">
            Support
          </span>
        </span>
        <span
          aria-hidden="true"
          class="inline-block transition-transform duration-300 ease-out group-hover:translate-x-0.5 group-focus-visible:translate-x-0.5"
        >
          →
        </span>
      </a>
    </nav>
  </div>
</header>
